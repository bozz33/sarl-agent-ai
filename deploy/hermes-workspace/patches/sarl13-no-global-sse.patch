diff --git a/src/server/profile-mcp-registry.ts b/src/server/profile-mcp-registry.ts
new file mode 100644
index 0000000..831595a
--- /dev/null
+++ b/src/server/profile-mcp-registry.ts
@@ -0,0 +1,84 @@
+import { existsSync, readFileSync, readdirSync, statSync } from 'node:fs'
+import { join } from 'node:path'
+import YAML from 'yaml'
+import { getProfilesDir } from './claude-paths'
+import {
+  maskSecretsInPlace,
+  normalizeMcpServerFromConfig,
+} from './mcp-normalize'
+import type { McpServer } from '../types/mcp'
+
+const PROFILE_NAME_RE = /^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$/
+
+type ProfileMcpServer = McpServer & {
+  profiles: Array<string>
+  readOnly: true
+}
+
+function readProfileServers(profile: string): Array<McpServer> {
+  const configPath = join(getProfilesDir(), profile, 'config.yaml')
+  if (!existsSync(configPath)) return []
+  try {
+    const config = YAML.parse(readFileSync(configPath, 'utf8')) as Record<
+      string,
+      unknown
+    >
+    const raw = config?.mcp_servers
+    if (!raw || typeof raw !== 'object' || Array.isArray(raw)) return []
+    const servers: Array<McpServer> = []
+    for (const [name, value] of Object.entries(raw)) {
+      const normalized = normalizeMcpServerFromConfig(name, value)
+      if (normalized) servers.push(maskSecretsInPlace(normalized))
+    }
+    return servers
+  } catch {
+    return []
+  }
+}
+
+export function listProfileMcpServers(): Array<ProfileMcpServer> {
+  const profilesDir = getProfilesDir()
+  if (!existsSync(profilesDir)) return []
+
+  const grouped = new Map<
+    string,
+    { server: McpServer; profiles: Array<string> }
+  >()
+  for (const profile of readdirSync(profilesDir).sort()) {
+    if (!PROFILE_NAME_RE.test(profile)) continue
+    const home = join(profilesDir, profile)
+    try {
+      if (!statSync(home).isDirectory()) continue
+    } catch {
+      continue
+    }
+    for (const server of readProfileServers(profile)) {
+      const key = JSON.stringify({
+        name: server.name,
+        transportType: server.transportType,
+        url: server.url ?? '',
+        command: server.command ?? '',
+        args: server.args,
+      })
+      const current = grouped.get(key)
+      if (current) {
+        current.profiles.push(profile)
+      } else {
+        grouped.set(key, { server, profiles: [profile] })
+      }
+    }
+  }
+
+  return [...grouped.values()]
+    .map(({ server, profiles }) => ({
+      ...server,
+      id: `profiles:${server.id}`,
+      profiles,
+      readOnly: true as const,
+    }))
+    .sort((a, b) => a.name.localeCompare(b.name))
+}
+
+export function hasProfileMcpServers(): boolean {
+  return listProfileMcpServers().length > 0
+}
