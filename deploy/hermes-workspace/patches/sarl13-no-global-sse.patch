+++ b/src/server/chat-work-tracking.test.ts
@@ -0,0 +1,56 @@
+import { describe, expect, it } from 'vitest'
+import {
+  buildChatWorkTitle,
+  isTrackableChatWork,
+  responseRequiresHumanApproval,
+} from './chat-work-tracking'
+
+describe('chat work tracking classification', () => {
+  it.each([
+    'Mets en place le suivi automatique des missions',
+    'Corrige ce bug de sécurité dans la plateforme puis exécute les tests et prépare un rollback.',
+    'Build the production application, verify the mobile layout, and create a deployment report.',
+    'Audite la stack Hermes complète et produis un rapport avec preuves, risques et patch proposé.',
+    'Crée une tâche Kanban pour la migration de la base de données.',
+  ])('tracks executable work: %s', (message) => {
+    expect(isTrackableChatWork(message)).toBe(true)
+  })
+
+  it.each([
+    'Est-ce que les tâches apparaissent dans Workspace ?',
+    'Pourquoi cette session est-elle lente ?',
+    'Comment fonctionne la mémoire ?',
+    'Bonjour',
+    'Merci',
+    'Écris un email de remerciement.',
+    'Crée un bref résumé de ce texte.',
+    'Teste cette phrase.',
+    'Donne-moi trois idées de titres.',
+  ])('does not track informational chat: %s', (message) => {
+    expect(isTrackableChatWork(message)).toBe(false)
+  })
+
+  it('creates a short stable task title', () => {
+    const title = buildChatWorkTitle(
+      'Crée un rapport très détaillé sur la configuration actuelle du projet et ajoute les recommandations prioritaires. Puis vérifie les résultats.',
+    )
+    expect(title.startsWith('Chat · Crée un rapport')).toBe(true)
+    expect(title.length).toBeLessThanOrEqual(103)
+  })
+
+  it.each([
+    'VALIDATION_HUMAINE_REQUISE: oui',
+    'Validation humaine requise : oui avant le redémarrage.',
+    'Awaiting your approval before deployment.',
+    'Je n’ai pas exécuté le changement : votre autorisation est nécessaire.',
+  ])('detects approval gates: %s', (response) => {
+    expect(responseRequiresHumanApproval(response)).toBe(true)
+  })
+
+  it.each([
+    'Validation humaine requise : non.',
+    'Le rapport est terminé et aucun changement critique n’a été appliqué.',
+  ])('does not invent approval gates: %s', (response) => {
+    expect(responseRequiresHumanApproval(response)).toBe(false)
+  })
+})
diff --git a/src/server/chat-work-tracking.ts b/src/server/chat-work-tracking.ts
new file mode 100644
index 0000000..523cfec
--- /dev/null
+++ b/src/server/chat-work-tracking.ts
@@ -0,0 +1,312 @@
+import { randomUUID } from 'node:crypto'
+import { mkdir, readFile, rename, writeFile } from 'node:fs/promises'
+import os from 'node:os'
+import path from 'node:path'
+import { createKanbanCard, updateKanbanCard } from './kanban-backend'
+
+type TrackingStatus = 'running' | 'complete' | 'blocked' | 'interrupted'
+
+type TrackingIndex = {
+  version: 1
+  requests: Record<
+    string,
+    {
+      taskId: string
+      reportPath: string | null
+      createdAt: number
+    }
+  >
+}
+
+export type ChatWorkTracking = {
+  taskId: string
+  idempotencyKey: string
+  title: string
+  request: string
+  sessionKey: string
+  friendlyId: string
+  workspaceRoot: string | null
+  reportPath: string | null
+  createdAt: number
+}
+
+type StartChatWorkTrackingInput = {
+  message: string
+  sessionKey: string
+  friendlyId: string
+  idempotencyKey?: string | null
+  workspaceRoot?: string | null
+}
+
+type FinishChatWorkTrackingInput = {
+  status: Exclude<TrackingStatus, 'running'>
+  summary?: string | null
+  error?: string | null
+}
+
+const HERMES_HOME =
+  process.env.HERMES_HOME ??
+  process.env.CLAUDE_HOME ??
+  path.join(os.homedir(), '.hermes')
+const TRACKING_INDEX_PATH = path.join(HERMES_HOME, 'chat-work-tracking.json')
+const ACTION_VERBS =
+  /\b(cr[eé]e(?:r|z)?|fais|faire|effectue(?:r|z)?|r[eé]alise(?:r|z)?|d[eé]veloppe(?:r|z)?|corrige(?:r|z)?|analyse(?:r|z)?|audite(?:r|z)?|pr[eé]pare(?:r|z)?|r[eé]dige(?:r|z)?|impl[eé]mente(?:r|z)?|mets?\s+en\s+place|d[eé]ploie(?:r|z)?|modifie(?:r|z)?|construis|construire|lance(?:r|z)?|g[eé]n[eè]re(?:r|z)?|teste(?:r|z)?|v[eé]rifie(?:r|z)?|installe(?:r|z)?|configure(?:r|z)?|recherche(?:r|z)?|organise(?:r|z)?|create|build|implement|fix|analy[sz]e|audit|prepare|write|deploy|modify|launch|generate|test|verify|install|configure|research|organize|set\s+up)\b/i
+const WORK_NOUNS =
+  /\b(mission|projet|project|t[aâ]che|task|rapport|report|livrable|deliverable|fonctionnalit[eé]|feature|application|site|audit|analyse|migration|d[eé]ploiement|deployment)\b/i
+const PURE_QUESTION =
+  /^(est[- ]ce que|pourquoi|comment|qu(?:'|’)est[- ]ce que|quelle?s?\b|quel?s?\b|o[uù]\b|when\b|why\b|how\b|what\b|where\b|is\b|are\b|do\b|does\b|can you tell me\b)/i
+const IMPORTANT_SCOPE =
+  /\b(projet|project|plateforme|platform|production|prod|syst[eè]me|system|infrastructure|stack|s[eé]curit[eé]|security|d[eé]ploiement|deployment|migration|base de donn[eé]es|database|architecture|int[eé]gration|integration|automatisation|automation|automatique|automatic|orchestrat(?:eur|ion)|workflow|telegram|api|workspace|hermes|incident|audit)\b/i
+const DURABLE_OUTPUT =
+  /\b(patch|code|configuration|config|rapport complet|full report|plan d['’]ex[eé]cution|implementation plan|livrable|deliverable|documentation|runbook|tests?|backup|rollback|monitoring|surveillance|suivi|tracking)\b/i
+const HIGH_RISK_ACTION =
+  /\b(d[eé]ploie|deploy|installe|install|migre|migrate|red[eé]marre|restart|supprime|delete|configure|s[eé]curise|secure|corrige|fix|impl[eé]mente|implement|modifie|modify|publie|publish)\b/i
+const EXPLICIT_TRACKING =
+  /\b(cr[eé]e|ouvre|ajoute|enregistre|suis|track)\b.{0,50}\b(t[aâ]che|task|kanban|mission|projet|project)\b/i
+
+function normalizeText(value: string): string {
+  return value.replace(/\s+/g, ' ').trim()
+}
+
+export function isTrackableChatWork(message: string): boolean {
+  const text = normalizeText(message)
+  if (text.length < 20) return false
+  if (PURE_QUESTION.test(text)) return false
+  if (EXPLICIT_TRACKING.test(text)) return true
+
+  // Do not turn every imperative chat message into durable project state.
+  // Tracking is reserved for substantial work with project/system scope,
+  // a durable output, multiple requested actions, or elevated operational risk.
+  const actionCount = (text.match(new RegExp(ACTION_VERBS.source, 'gi')) ?? [])
+    .length
+  let score = 0
+  if (ACTION_VERBS.test(text)) score += 1
+  if (IMPORTANT_SCOPE.test(text)) score += 2
+  if (DURABLE_OUTPUT.test(text)) score += 1
+  if (HIGH_RISK_ACTION.test(text)) score += 2
+  if (WORK_NOUNS.test(text)) score += 1
+  if (actionCount >= 2) score += 1
+  if (text.length >= 220) score += 1
+  return score >= 4
+}
+
+export function buildChatWorkTitle(message: string): string {
+  const normalized = normalizeText(
+    message.replace(/```[\s\S]*?```/g, ' ').replace(/[#>*_`[\]()]/g, ' '),
+  )
+  const firstSentence = normalized.split(/(?<=[.!?])\s+/)[0] || normalized
+  const clipped =
+    firstSentence.length > 96
+      ? `${firstSentence.slice(0, 93).trimEnd()}...`
+      : firstSentence
+  return `Chat · ${clipped || 'Mission sans titre'}`
+}
+
+export function responseRequiresHumanApproval(response: string): boolean {
+  const text = normalizeText(response.replace(/_/g, ' '))
+  if (!text) return false
+  return (
+    /\bvalidation humaine requise\s*[:=-]?\s*(oui|yes)\b/i.test(text) ||
+    /\b(human approval|manual approval|approbation humaine)\s+(is\s+)?required\b/i.test(
+      text,
+    ) ||
+    /\b(en attente de|attendre|awaiting|pending)\s+(votre\s+|your\s+)?(validation|approbation|autorisation|approval)\b/i.test(
+      text,
+    ) ||
+    /\bje n['’]ai pas (ex[eé]cut[eé]|appliqu[eé]|d[eé]ploy[eé]|red[eé]marr[eé]).{0,120}\b(validation|approbation|autorisation)\b/i.test(
+      text,
+    )
+  )
+}
+
+function safeExcerpt(value: string | null | undefined, max = 2000): string {
+  const normalized = normalizeText(value ?? '')
+  if (!normalized) return ''
+  return normalized.length > max
+    ? `${normalized.slice(0, max - 3).trimEnd()}...`
+    : normalized
+}
+
+function trackingDescription(input: {
+  request: string
+  sessionKey: string
+  friendlyId: string
+  status: TrackingStatus
+  reportPath?: string | null
+  summary?: string | null
+  error?: string | null
+}): string {
+  return [
+    'Source: Workspace Chat',
+    `Statut de suivi: ${input.status}`,
+    `Session: ${input.sessionKey}`,
+    `Alias: ${input.friendlyId || input.sessionKey}`,
+    input.reportPath ? `Rapport: ${input.reportPath}` : null,
+    '',
+    'Demande:',
+    safeExcerpt(input.request, 4000),
+    input.summary ? ['', 'Résultat:', safeExcerpt(input.summary)] : null,
+    input.error ? ['', 'Blocage:', safeExcerpt(input.error)] : null,
+  ]
+    .flat()
+    .filter((line): line is string => typeof line === 'string')
+    .join('\n')
+}
+
+async function readIndex(): Promise<TrackingIndex> {
+  try {
+    const parsed = JSON.parse(
+      await readFile(TRACKING_INDEX_PATH, 'utf8'),
+    ) as Partial<TrackingIndex>
+    return {
+      version: 1,
+      requests:
+        parsed.requests && typeof parsed.requests === 'object'
+          ? parsed.requests
+          : {},
+    }
+  } catch {
+    return { version: 1, requests: {} }
+  }
+}
+
+async function writeIndex(index: TrackingIndex): Promise<void> {
+  await mkdir(path.dirname(TRACKING_INDEX_PATH), { recursive: true })
+  const tmp = `${TRACKING_INDEX_PATH}.${process.pid}.${randomUUID()}.tmp`
+  await writeFile(tmp, `${JSON.stringify(index, null, 2)}\n`, 'utf8')
+  await rename(tmp, TRACKING_INDEX_PATH)
+}
+
+function resolveReportPath(
+  workspaceRoot: string | null,
+  taskId: string,
+): { absolute: string; relative: string } | null {
+  if (!workspaceRoot || !path.isAbsolute(workspaceRoot)) return null
+  const relative = path.join('reports', 'chat-missions', `${taskId}.md`)
+  return { absolute: path.join(workspaceRoot, relative), relative }
+}
+
+async function writeReport(
+  tracking: ChatWorkTracking,
+  status: TrackingStatus,
+  summary?: string | null,
+  error?: string | null,
+): Promise<void> {
+  if (!tracking.workspaceRoot) return
+  const resolved = resolveReportPath(tracking.workspaceRoot, tracking.taskId)
+  if (!resolved) return
+  await mkdir(path.dirname(resolved.absolute), { recursive: true })
+  const body = [
+    `# ${tracking.title.replace(/^Chat · /, '')}`,
+    '',
+    `- Tâche : \`${tracking.taskId}\``,
+    `- Source : Workspace Chat`,
+    `- Session : \`${tracking.sessionKey}\``,
+    `- Statut : \`${status}\``,
+    `- Créée : ${new Date(tracking.createdAt).toISOString()}`,
+    `- Mise à jour : ${new Date().toISOString()}`,
+    '',
+    '## Demande',
+    '',
+    tracking.request.trim(),
+    summary ? ['', '## Résultat', '', safeExcerpt(summary, 8000)] : [],
+    error ? ['', '## Blocage', '', safeExcerpt(error, 4000)] : [],
+    '',
+  ]
+    .flat()
+    .join('\n')
+  await writeFile(resolved.absolute, body, 'utf8')
+}
+
+export async function startChatWorkTracking(
+  input: StartChatWorkTrackingInput,
+): Promise<ChatWorkTracking | null> {
+  if (!isTrackableChatWork(input.message)) return null
+
+  const request = input.message.trim()
+  const idempotencyKey =
+    input.idempotencyKey?.trim() || `chat-${input.sessionKey}-${randomUUID()}`
+  const index = await readIndex()
+  const existing = index.requests[idempotencyKey]
+  if (existing) {
+    return {
+      taskId: existing.taskId,
+      idempotencyKey,
+      title: buildChatWorkTitle(request),
+      request,
+      sessionKey: input.sessionKey,
+      friendlyId: input.friendlyId,
+      workspaceRoot: input.workspaceRoot?.trim() || null,
+      reportPath: existing.reportPath,
+      createdAt: existing.createdAt,
+    }
+  }
+
+  const title = buildChatWorkTitle(request)
+  const createdAt = Date.now()
+  const card = await createKanbanCard({
+    title,
+    spec: trackingDescription({
+      request,
+      sessionKey: input.sessionKey,
+      friendlyId: input.friendlyId,
+      status: 'running',
+    }),
+    status: 'running',
+    assignedWorker: null,
+    createdBy: 'workspace-chat',
+    idempotencyKey: `workspace-chat:${idempotencyKey}`,
+    tags: ['workspace-chat'],
+  })
+  const report = resolveReportPath(input.workspaceRoot?.trim() || null, card.id)
+  const tracking: ChatWorkTracking = {
+    taskId: card.id,
+    idempotencyKey,
+    title,
+    request,
+    sessionKey: input.sessionKey,
+    friendlyId: input.friendlyId,
+    workspaceRoot: input.workspaceRoot?.trim() || null,
+    reportPath: report?.relative ?? null,
+    createdAt,
+  }
+
+  index.requests[idempotencyKey] = {
+    taskId: card.id,
+    reportPath: tracking.reportPath,
+    createdAt,
+  }
+  await writeIndex(index)
+  await updateKanbanCard(card.id, {
+    spec: trackingDescription({
+      request,
+      sessionKey: input.sessionKey,
+      friendlyId: input.friendlyId,
+      status: 'running',
+      reportPath: tracking.reportPath,
+    }),
+  })
+  await writeReport(tracking, 'running')
+  return tracking
+}
+
+export async function finishChatWorkTracking(
+  tracking: ChatWorkTracking | null,
+  input: FinishChatWorkTrackingInput,
+): Promise<void> {
+  if (!tracking) return
+  const column = input.status === 'complete' ? 'done' : 'blocked'
+  await updateKanbanCard(tracking.taskId, {
+    status: column,
+    spec: trackingDescription({
+      request: tracking.request,
+      sessionKey: tracking.sessionKey,
+      friendlyId: tracking.friendlyId,
+      status: input.status,
+      reportPath: tracking.reportPath,
+      summary: input.summary,
+      error: input.error,
+    }),
+  })
+  await writeReport(tracking, input.status, input.summary, input.error)
+}
